# === HTTP Server ===
# Адрес привязки (0.0.0.0 = все интерфейсы)
SERVER_HOST=0.0.0.0

# Порт веб-сервера
SERVER_PORT=8080

# === База данных (SQLite) ===
# Путь к файлу БД относительно рабочей директории контейнера
DB_PATH=data/domains.db

# === Аутентификация ===
# Имя пользователя для админ-панели
AUTH_USERNAME=admin

# Пароль для админ-панели (смените на production!)
AUTH_PASSWORD=admin

# === Fetcher ===
# Таймаут HTTP-запросов в секундах
FETCHER_TIMEOUT=30

# Максимальное число повторных попыток
FETCHER_MAX_RETRIES=3

# Максимальный размер тела ответа (в байтах, 50MB)
FETCHER_MAX_BODY_SIZE=52428800

# Максимальное число редиректов
FETCHER_MAX_REDIRECTS=10

# === Builder ===
# Сколько последних снимков хранить
BUILDER_SNAPSHOT_COUNT=10

# Путь к выходному файлу domains.lst
BUILDER_OUTPUT_PATH=output/domains.lst
